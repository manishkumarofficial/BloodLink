# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE CONFIGURATION: Key configuration properties for connecting to your real Firebase project.
# Access securely via BuildConfig in code.
FIREBASE_API_KEY=PLACEHOLDER_API_KEY
FIREBASE_PROJECT_ID=PLACEHOLDER_PROJECT_ID
FIREBASE_APPLICATION_ID=PLACEHOLDER_APP_ID
FIREBASE_STORAGE_BUCKET=PLACEHOLDER_STORAGE_BUCKET
FIREBASE_DATABASE_URL=PLACEHOLDER_DATABASE_URL
FIREBASE_GCM_SENDER_ID=PLACEHOLDER_GCM_SENDER_ID

